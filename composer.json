{
    "name": "sasco/libredte",
    "description": "Biblioteca para trabajo con DTE del SII de Chile",
    "type": "library",
    "keywords": ["dte", "sii", "facturación electrónica"],
    "homepage": "https://www.libredte.cl",
    "license": "AGPL-3.0+",
    "authors": [
        {
            "name": "LibreDTE",
            "homepage": "https://www.libredte.cl"
        }
    ],
    "support": {
        "issues": "https://github.com/LibreDTE/libredte-lib-core/issues",
        "source": "https://github.com/LibreDTE/libredte-lib-core"
    },
    "autoload": {
        "psr-4": {"sasco\\LibreDTE\\": "lib/"}
    },
    "require": {
        "php": "^7.3",
        "ext-curl": "*",
        "ext-openssl": "*",
        "ext-soap": "*",
        "phpseclib/phpseclib": "2.0.51",
        "tecnickcom/tcpdf": "6.11.2"
    },
    "require-dev": {
        "phpunit/phpunit": "9.6.34"
    }
}
