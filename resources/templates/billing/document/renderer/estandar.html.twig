<html>
<head>
    <style>
        {# Estilos globales #}
        html {
            height: 100%;
        }
        body {
            font-family: Arial, sans-serif;
            font-size: 10pt;
            height: 100%;
        }
        p {
            margin: 5px 0;
        }
        {# Estilo detalle #}
        .label {
            font-weight: bold;
            width: 25%;
        }
        .bold {
            font-weight: bold;
        }
        {# Contenedores generales #}
        .container {
            display: flex;
            justify-content: space-between;
            width: 100%;
        }
        .container-detalles {
            margin-top: 15pt;
            display: flex;
            justify-content: space-between;
        }
        .container-montos-globales {
            display: flex;
            justify-content: flex-end;
            margin-top: 10px;
            margin-left: auto;
        }
        .container-observacion {
            font-size: 9pt;
            bottom: 40mm;
            align-items: flex-end;
        }
        {# Información del Emisor #}
        .emisor-info {
            font-weight: bold;
            float: left;
            width: 50%;
            text-align: left;
            font-size: 7pt;
            line-height: 1;
        }
        .emisor-logo {
            max-width: 30mm;
            height: auto;
        }
        .emisor-razon-social {
            color: rgb(0, 64, 128);
            font-weight: bold;
            font-size: 14pt;
        }
        .emisor-giro {
            color: black;
            font-weight: bold;
        }
        .emisor-direccion {
            color: black;
        }
        {# Información del DTE #}
        .container-dte {
            float:right;
            width: 45%;
            text-align: center;
            color: rgb(255, 0, 0);
            font-weight: bold;
            text-transform: uppercase;
        }
        .dte-informacion {
            min-height: 20mm;
            max-height: 40mm;
            min-width: 50mm;
            max-width: 90mm;
            border: 0.7mm solid rgb(255, 0, 0);
            font-size: 15pt;
        }
        .tipo-documento {
            font-size: 12pt;
        }
        .sucursal-sii {
            margin-top: 5px;
            font-size: 10pt;
            color: rgb(255, 0, 0);
        }
        {# Información Receptor y Fechas #}
        .receptor-info {
            float: left;
            width: 68%;
        }
        .fechas {
            float: right;
            text-align: right;
        }
        {# Tablas Generales #}
        .tabla-detalles {
            width: 100%;
            border-collapse: collapse;
            font-size: 10pt;
            border: 1px solid black;
        }
        .tabla-detalles th, .tabla-detalles td {
            white-space: nowrap;
            padding: 2px;
            border-left: 1px solid black;
            border-right: 1px solid black;
            text-align: center;
        }
        .tabla-detalles th {
            text-align: left;
            font-weight: bold;
            border-bottom: 1px solid black;
        }
        {# Tablas Receptor #}
        .tabla-receptor {
            border: none;
            border-collapse: collapse;
            width: 100%;
            text-align: left;
            font-size: 10pt;
            table-layout: fixed;
        }
        .tabla-receptor td {
            border: none;
            text-align: left;
            line-height: 1;
            word-wrap: break-word;
            white-space: normal;
            padding: 2px 0;
        }
        {# Tabla montos globales #}
        .tabla-montos-global {
            border: none;
            width: 50px;
            font-size: 11pt;
            margin-left: auto;
        }
        .tabla-montos-global td {
            white-space: nowrap;
            font-weight: bold;
            padding: 2px 5px;
            border: none;
            text-align: right;
        }
        {# Tabla de montos -#}
        .tabla-montos {
            border: none;
            width: 100%;
            font-size: 13px;
            border-collapse: collapse;
            text-align: right;
            margin-left: auto;
            padding-right: 0%;
        }
        .tabla-montos td {
            white-space: normal;
            font-weight: bold;
            border: none;
            text-align: right;
        }
        {# Tabla timbre#}
        .tabla-timbre {
            margin-right: auto;
            border-collapse: collapse;
            text-align: center;
            width: 100%;
            height: 100%;
        }
        .tabla-timbre td {
                text-align:center;
                padding: 0;
                line-height: 0.9;
        }
        .tabla-timbre .timbre-text {
            font-size: 10pt;
            margin: 2px;
            text-align: center;
        }
        .tabla-timbre .img-timbre {
            margin: 0;
            padding: 0;
        }
        {# Tabla Bottom Element #}
        .tabla-bottom-element {
            width: 100%;
            border-collapse: collapse;
            table-layout: fixed;
            flex: 1;
        }
        .tabla-bottom-element > tbody > tr {
            height: 100%;
        }
        .tabla-bottom-element td {
            border: none;
            vertical-align: top;
        }
        .tabla-bottom-element-cell {
            width: 33%;
            height: 100%;
            vertical-align: top;
        }
        .tabla-bottom-element-cell table {
            max-height: 100%;
            height: 100%;
            max-height: auto;
            overflow: hidden;
            border-collapse: collapse;
            width: 100%;
        }
        {# Estilo de montos #}
        .montos {
            text-align: right;
            width: 50%;
            font-weight: bold;
            font-family: Arial, sans-serif;
            font-size: 11pt;
        }
        .montos div {
            margin-bottom: 5px;
        }
        .montos span {
            display: inline-block;
            min-width: 100px;
        }
        {# Acuse recibo #}
        .acuse-recibo {
            width: 100%;
            border-collapse: collapse;
            border: 1px solid black;
        }
        .acuse-recibo td {
            padding: 5px;
            vertical-align: bottom;
            border: none;
            text-align: left;
        }
        .acuse-recibo .acuse-title {
            text-align: center;
            font-weight: bold;
            padding: 10px;
        }
        .acuse-recibo-label {
            text-align: justify;
            margin-top: 5px;
            width: 90%;
            margin-left: auto;
            margin-right: auto;
            font-size: 8pt;
        }
        .acuse-recibo .linea {
            width: 70%;
            text-align: left;
        }
        .graph-img {
            border:1px solid black;
            height: 150px;
            text-align: center;
        }
        .cedible {
            font-size: 15pt;
            text-align: right;
            font-weight: bold;
            margin-left: auto;
        }
        .container-footer{
            display: table;
            justify-content: space-between;
            width: 100%;
        }
        .footer-text{
            float: left;
            width: 50%;
            text-align:left;
        }
        .footer-link{
            width: 20%;
            text-align:right;
        }
        @media print {
            @page {
                size: 216mm 260mm;
                margin: 5mm;
            }
            .container-dte {
                display: flex;
            }
            .dte-informacion p {
                padding: 1.5mm;
                margin: 0;
            }
            .container-informacion-bottom {
                position: absolute;
                bottom: 0;
                left: 0;
                width: 98%;
                min-height: 150px;
            }
            .container-cedible {
                position: fixed;
                bottom: 0px;
            }
            .img-timbre {
                width: 60mm;
                height: 35mm;
            }
            footer {
                position: absolute;
                bottom: 0;
                left: 0;
                width: 100%;
                text-align: center;
                font-weight: bold;
                font-size: 8pt;
                border-top: 1px solid #000;
                padding: 5px 0;
                margin-top: 10px;
                background-color: #fff;
                padding-top: 5px;
            }
            .footer-link{
                width: 47%;
                text-align:right;
            }
        }
        @media screen {
            body {
                font-size: 12pt;
                margin: 10px;
                min-height: 100%;
            }

            .tabla-detalles th, .tabla-detalles td {
                font-size: 11pt;
                padding: 5px;
            }
            .container {
                flex-wrap: wrap;
            }
            .container-dte {
                min-width: 70mm;
                height: auto;
                margin: 0;
            }
            .dte-informacion p {
                margin: 5px 0;
            }
            .sucursal-sii {
                margin-top: 10px;
                font-size: 10pt;
                color: rgb(255, 0, 0);
            }
        }
    </style>
</head>
    <body>
        <div class="container">
            {# Información del Emisor #}
            <div class="emisor-info">
                {# Logotipo #}
                {% if document.logo is not empty %}
                    <img src="{{ document.logo }}" alt="Logotipo Emisor" class="emisor-logo">
                {% endif %}
                {# Razón Social del Emisor #}
                <p class="emisor-razon-social">
                    {{ document.Encabezado.Emisor.RznSoc
                        | default(document.Encabezado.Emisor.RznSocEmisor) }}
                </p>
                {# Giro del Emisor #}
                <p class="emisor-giro">
                    {{ document.Encabezado.Emisor.GiroEmis
                        | default(document.Encabezado.Emisor.GiroEmisor) }}
                </p>
                {# Dirección del Emisor #}
                <p class="emisor-direccion">
                    {{ [document.Encabezado.Emisor.DirOrigen, document.Encabezado.Emisor.CmnaOrigen]
                        | filter(v => v is not empty)
                        | join(', ')
                    }}
                </p>
                {# Teléfono y correo del Emisor -#}
                {% set contacto_emisor = [document.Encabezado.Emisor.Telefono, document.Encabezado.Emisor.CorreoEmisor] | filter(v => v is not empty) %}
                {% if contacto_emisor is not empty %}
                <p class="emisor-contacto">{{ contacto_emisor | join(' / ') }}</p>
                {% endif %}
            </div>
            <div class="container-dte">
                {# Información del DTE #}
                <div class="dte-informacion">
                    <p>
                        R.U.T.: {{ document.Encabezado.Emisor.RUTEmisor
                            | format_as('billing_document.RUTEmisor') }}
                    </p>
                    <p class="tipo-documento">
                        {{ document.Encabezado.IdDoc.TipoDTE
                            | format_as('billing_document.TipoDTE') }}
                    </p>
                    <p>
                        N° {{ document.Encabezado.IdDoc.Folio }}
                    </p>
                </div>
                {# Sucursal SII #}
                <p class="sucursal-sii">
                    S.I.I. - {{ document.Encabezado.Emisor.CmnaOrigen
                    | format_as('billing_document.CdgSIISucur') }}
                </p>
            </div>
        </div>
        <div class="container">
            {# Información del Receptor #}
            <div class="receptor-info">
                <table class="tabla-receptor">
                    <tbody>
                        {# Información del Receptor #}
                        {% if document.Encabezado.Receptor.RUTRecep != '66666666-6' %}
                            <tr>
                                <td class="bold">R.U.T.</td>
                                <td>:</td>
                                <td>
                                    {{ document.Encabezado.Receptor.RUTRecep
                                        | format_as('billing_document.RUTRecep') }}
                                    </td>
                            </tr>
                        {% endif %}
                        {# Razón Social #}
                        {% if document.Encabezado.Receptor.RznSocRecep is not empty %}
                            <tr>
                                <td class="bold">Razón Social</td>
                                <td>:</td>
                                <td>
                                    {{ document.Encabezado.Receptor.RznSocRecep }}
                                </td>
                            </tr>
                        {% endif %}
                        {# Giro #}
                        {% if document.Encabezado.Receptor.GiroRecep is not empty %}
                        <tr>
                            <td class="bold">Giro</td>
                                <td>:</td>
                            <td>
                                {{ document.Encabezado.Receptor.GiroRecep }}
                            </td>
                        </tr>
                        {% endif %}
                        {# Dirección #}
                        {% if document.Encabezado.Receptor.DirRecep is not empty %}
                            <tr>
                                <td class="bold">Dirección</td>
                                <td>:</td>
                                <td>
                                    {{
                                        [
                                            document.Encabezado.Receptor.DirRecep,
                                            document.Encabezado.Receptor.CmnaRecep,
                                            document.Encabezado.Receptor.CiudadRecep
                                        ]
                                        | filter(v => v is not empty)
                                        | join(', ')
                                    }}
                                </td>
                            </tr>
                        {% endif %}
                        {# Tipo de Operación #}
                        {% if document.Encabezado.IdDoc.IndTraslado is not empty %}
                            <tr>
                                <td class="bold">Tipo oper.</td>
                                <td>:</td>
                                <td>
                                    {{ document.Encabezado.IdDoc.IndTraslado
                                        | format_as('billing_document.IndTraslado') }}
                                </td>
                            </tr>
                        {% endif %}
                        {# Aduana - Modalidad de venta #}
                        {% if document.Encabezado.Transporte.Aduana.CodModVenta is not empty %}
                            <tr>
                                <td class="bold">Mod. venta</td>
                                <td>:</td>
                                <td>{{ document.Encabezado.Transporte.Aduana.CodModVenta | format_as('billing_document.CodModVenta') }}</td>
                            </tr>
                        {% endif %}
                        {# Aduana - Total cláusula de venta #}
                        {% if document.Encabezado.Transporte.Aduana.TotClauVenta is not empty %}
                            <tr>
                                <td class="bold">Total claú.</td>
                                <td>:</td>
                                <td>{{ document.Encabezado.Transporte.Aduana.TotClauVenta }}</td>
                            </tr>
                        {% endif %}
                        {# Aduana - Puerto de embarque #}
                        {% if document.Encabezado.Transporte.Aduana.CodPtoEmbarque is not empty %}
                            <tr>
                                <td class="bold">Embarque</td>
                                <td>:</td>
                                <td>{{ document.Encabezado.Transporte.Aduana.CodPtoEmbarque | format_as('billing_document.CodPtoEmbarque') }}</td>
                            </tr>
                        {% endif %}
                        {# Aduana - Unidad tara #}
                        {% if document.Encabezado.Transporte.Aduana.CodUnidMedTara is not empty %}
                            <tr>
                                <td class="bold">U. tara</td>
                                <td>:</td>
                                <td>{{ document.Encabezado.Transporte.Aduana.CodUnidMedTara | format_as('billing_document.CodUnidMedTara') }}</td>
                            </tr>
                        {% endif %}
                        {# Aduana - Unidad peso neto #}
                        {% if document.Encabezado.Transporte.Aduana.CodUnidPesoNeto is not empty %}
                            <tr>
                                <td class="bold">U. p. neto</td>
                                <td>:</td>
                                <td>{{ document.Encabezado.Transporte.Aduana.CodUnidPesoNeto | format_as('billing_document.CodUnidPesoNeto') }}</td>
                            </tr>
                        {% endif %}
                        {# Aduana - Tipo de bultos #}
                        {% if document.Encabezado.Transporte.Aduana.TipoBultos is not empty %}
                            {% set tipoBultosArr = document.Encabezado.Transporte.Aduana.TipoBultos %}
                            {% if tipoBultosArr.CodTpoBultos is defined %}{% set tipoBultosArr = [tipoBultosArr] %}{% endif %}
                            {% for bulto in tipoBultosArr %}
                                <tr>
                                    <td class="bold">Bultos</td>
                                    <td>:</td>
                                    <td>
                                        {{ bulto.CantBultos }}
                                        {% if bulto.CodTpoBultos is not empty %}{{ bulto.CodTpoBultos | format_as('billing_document.CodTpoBultos') }}{% endif %}
                                        {% if bulto.Marcas is not empty %}({{ bulto.Marcas }}){% endif %}
                                    </td>
                                </tr>
                            {% endfor %}
                        {% endif %}
                        {# Aduana - Flete #}
                        {% if document.Encabezado.Transporte.Aduana.MntFlete is not empty %}
                            <tr>
                                <td class="bold">Flete</td>
                                <td>:</td>
                                <td>{{ document.Encabezado.Transporte.Aduana.MntFlete }}</td>
                            </tr>
                        {% endif %}
                        {# Aduana - Seguro #}
                        {% if document.Encabezado.Transporte.Aduana.MntSeguro is not empty %}
                            <tr>
                                <td class="bold">Seguro</td>
                                <td>:</td>
                                <td>{{ document.Encabezado.Transporte.Aduana.MntSeguro }}</td>
                            </tr>
                        {% endif %}
                        {# Traslado (destino físico) - solo si hay datos de destino o transportista #}
                        {% set traslado_dest = [document.Encabezado.Transporte.DirDest, document.Encabezado.Transporte.CmnaDest] | filter(v => v is not empty) | join(', ') %}
                        {% if traslado_dest is not empty or document.Encabezado.Transporte.RUTTrans is not empty or document.Encabezado.Transporte.Patente is not empty or document.Encabezado.Transporte.Chofer.NombreChofer is not empty %}
                            <tr>
                                <td class="bold">Traslado</td>
                                <td>:</td>
                                <td>
                                    {% if traslado_dest is not empty %}A {{ traslado_dest }}{% endif %}
                                    {% if document.Encabezado.Transporte.RUTTrans is not empty %}
                                        por {{ document.Encabezado.Transporte.RUTTrans | format_as('billing_document.RUTTrans') }}
                                    {% endif %}
                                    {% if document.Encabezado.Transporte.Patente is not empty %}
                                        en vehículo {{ document.Encabezado.Transporte.Patente }}
                                    {% endif %}
                                    {% if document.Encabezado.Transporte.Chofer.NombreChofer is not empty %}
                                        con chofer {{ document.Encabezado.Transporte.Chofer.NombreChofer }}
                                        {% if document.Encabezado.Transporte.Chofer.RUTChofer is not empty %}
                                            ({{ document.Encabezado.Transporte.Chofer.RUTChofer | format_as('billing_document.RUTChofer') }})
                                        {% endif %}
                                    {% endif %}
                                </td>
                            </tr>
                        {% endif %}
                        {# País receptor #}
                        {% if document.Encabezado.Transporte.Aduana.CodPaisRecep is not empty %}
                            <tr>
                                <td class="bold">P. receptor</td>
                                <td>:</td>
                                <td>
                                    {{ document.Encabezado.Transporte.Aduana.CodPaisRecep
                                        | format_as('billing_document.CodPaisRecep') }}
                                </td>
                            </tr>
                        {% endif %}
                        {# País de destino #}
                        {% if document.Encabezado.Transporte.Aduana.CodPaisDestin is not empty %}
                            <tr>
                                <td class="bold">P. destino</td>
                                <td>:</td>
                                <td>
                                    {{ document.Encabezado.Transporte.Aduana.CodPaisDestin
                                        | format_as('billing_document.CodPaisDestin') }}
                                </td>
                            </tr>
                        {% endif %}
                        {# Contacto #}
                        {% if document.Encabezado.Receptor.CorreoRecep is not empty or document.Encabezado.Receptor.Contacto is not empty %}
                            <tr>
                                <td class="bold">Contacto</td>
                                <td>:</td>
                                <td>
                                    {% set contacto_receptor = [document.Encabezado.Receptor.Contacto, document.Encabezado.Receptor.CorreoRecep] | filter(v => v is not empty) %}
                                    {{ contacto_receptor | join(' / ') }}
                                </td>
                            </tr>
                        {% endif %}
                        {# Nacionalidad #}
                        {% if document.Encabezado.Receptor.Extranjero.Nacionalidad is not empty %}
                            <tr>
                                <td class="bold">Nacionalidad</td>
                                <td>:</td>
                                <td>
                                    {{ document.Encabezado.Receptor.Extranjero.Nacionalidad
                                        | format_as('billing_document.Nacionalidad') }}
                                </td>
                            </tr>
                        {% endif %}
                        {# Cód. recep #}
                        {% if document.Encabezado.Receptor.CdgIntRecep is not empty %}
                            <tr>
                                <td class="bold">Cód. recep.</td>
                                <td>:</td>
                                <td>
                                    {{ document.Encabezado.Receptor.CdgIntRecep }}
                                </td>
                            </tr>
                        {% endif %}
                        {# Referencias #}
                        {% if document.Referencia is not empty %}
                            {% for referencia in document.Referencia %}
                            <tr>
                                <td class="bold">Referencia</td>
                                <td>:</td>
                                <td>
                                    {{ loop.index }} -
                                    {% if referencia.TpoDocRef is not empty %}
                                        {{ referencia.TpoDocRef | format_as('billing_document.TpoDocRef') }}
                                    {% endif %}
                                    {% if referencia.FolioRef is defined and referencia.IndGlobal != 1 %}
                                        {% if referencia.FolioRef matches '/^[0-9]+$/' %}N° {% endif %}{{ referencia.FolioRef }}
                                    {% endif %}
                                    {% if referencia.FchRef is not empty %}
                                        del {{ referencia.FchRef | date('d/m/Y') }}
                                    {% endif %}
                                    {% if referencia.RazonRef is not empty %}
                                        : {{ referencia.RazonRef }}
                                    {% endif %}
                                </td>
                            </tr>
                            {% endfor %}
                        {% endif %}
                    </tbody>
                </table>

            </div>
            <div class="fechas">
                {# Fecha de Emisión -#}
                <p class="bold">
                    {{ document.Encabezado.IdDoc.FchEmis
                        | format_as('billing_document.FchEmis')  }}
                </p>
                {# Fecha de Vencimiento -#}
                {% if document.Encabezado.IdDoc.FchVenc is not empty %}
                    <p>
                        Vence el {{ document.Encabezado.IdDoc.FchVenc
                            | format_as('billing_document.FchVenc')  }}
                    </p>
                {% endif %}
                {# Período Desde/Hasta -#}
                {% if document.Encabezado.IdDoc.PeriodoDesde is not empty and
                    document.Encabezado.IdDoc.PeriodoHasta is not empty %}
                    <p>
                        Período del {{ document.Encabezado.IdDoc.PeriodoDesde
                            | format_as('billing_document.PeriodoDesde')  }}
                        al {{ document.Encabezado.IdDoc.PeriodoHasta
                            | format_as('billing_document.PeriodoHasta')  }}
                    </p>
                {% endif %}
                {# Forma de Pago -#}
                {% if document.Encabezado.IdDoc.FmaPago is not empty %}
                    <p>Venta: {{ document.Encabezado.IdDoc.FmaPago
                        | format_as('billing_document.FmaPago') }}</p>
                {% endif %}
                {# Vendedor -#}
                {% if document.Encabezado.Emisor.CdgVendedor is not empty %}
                    <p>Vendedor: {{ document.Encabezado.Emisor.CdgVendedor }}</p>
                {% endif %}
                {# Aduana - campos columna derecha #}
                {% if document.Encabezado.Transporte.Aduana.CodClauVenta is not empty %}
                    <p>Claú. venta: {{ document.Encabezado.Transporte.Aduana.CodClauVenta | format_as('billing_document.CodClauVenta') }}</p>
                {% endif %}
                {% if document.Encabezado.Transporte.Aduana.CodViaTransp is not empty %}
                    <p>Transporte: {{ document.Encabezado.Transporte.Aduana.CodViaTransp | format_as('billing_document.CodViaTransp') }}</p>
                {% endif %}
                {% if document.Encabezado.Transporte.Aduana.CodPtoDesemb is not empty %}
                    <p>Desembarq.: {{ document.Encabezado.Transporte.Aduana.CodPtoDesemb | format_as('billing_document.CodPtoDesemb') }}</p>
                {% endif %}
                {% if document.Encabezado.Transporte.Aduana.CodUnidPesoBruto is not empty %}
                    <p>U. p. bruto: {{ document.Encabezado.Transporte.Aduana.CodUnidPesoBruto | format_as('billing_document.CodUnidPesoBruto') }}</p>
                {% endif %}
                {% if document.Encabezado.Transporte.Aduana.TotBultos is not empty %}
                    <p>Total bultos: {{ document.Encabezado.Transporte.Aduana.TotBultos }}</p>
                {% endif %}
            </div>
        </div>
        <div class="container container-detalles">
            <table class="tabla-detalles">
                {# Encabezados de la Tabla -#}
                <thead>
                    <tr>
                        {% set columns = {
                            'codigo': {
                                'show': (document.Detalle ?? []) | filter(detalle => detalle.CdgItem is defined and detalle.CdgItem is not empty and detalle.CdgItem.VlrCodigo is not empty) | length > 0,
                                'title': 'Código',
                                'width': '10%',
                                'align': 'left',
                                'value': 'CdgItem',
                                'format': null,
                            },
                            'item': {
                                'show': (document.Detalle ?? []) | filter(detalle => detalle.NmbItem is defined and detalle.NmbItem is not empty) | length > 0,
                                'title': 'Ítem',
                                'width': '64%',
                                'align': 'left',
                                'value': 'NmbItem',
                                'format': null,
                                'description': 'DscItem'
                            },
                            'indexe': {
                                'show': document.Encabezado.IdDoc.TipoDTE not in [34, 110, 111, 112] and (document.Detalle ?? []) | filter(detalle => detalle.IndExe is defined and detalle.IndExe is not empty) | length > 0,
                                'title': 'IE',
                                'width': '5%',
                                'align': 'left',
                                'value': 'IndExe',
                                'format': 'indexe'
                            },
                            'cantidad': {
                                'show': (document.Detalle ?? []) | filter(detalle => detalle.QtyItem is defined and detalle.QtyItem is not empty) | length > 0,
                                'title': 'Cant.',
                                'width': '12%',
                                'align': 'right',
                                'value': 'QtyItem',
                                'format': 'number'
                            },
                            'unidad': {
                                'show': (document.Detalle ?? []) | filter(detalle => detalle.UnmdItem is defined and detalle.UnmdItem is not empty) | length > 0,
                                'title': 'Unidad',
                                'width': '10%',
                                'align': 'left',
                                'value': 'UnmdItem',
                                'format': null
                            },
                            'precio_unitario': {
                                'show': (document.Detalle ?? []) | filter(detalle => detalle.PrcItem is defined and detalle.PrcItem is not empty) | length > 0,
                                'title': 'P. Unitario',
                                'width': 'auto',
                                'align': 'right',
                                'value': 'PrcItem',
                                'format': 'number'
                            },
                            'descuento': {
                                'show': (document.Detalle ?? []) | filter(detalle => (detalle.DescuentoMonto is defined and detalle.DescuentoMonto is not empty) or (detalle.DescuentoPct is defined and detalle.DescuentoPct is not empty)) | length > 0,
                                'title': 'Descuento',
                                'width': '10%',
                                'align': 'right',
                                'value': 'DescuentoMonto',
                                'format': 'number'
                            },
                            'total_item': {
                                'show': (document.Detalle ?? []) | filter(detalle => detalle.MontoItem is not empty) | length > 0,
                                'title': 'Total Ítem',
                                'width': '12%',
                                'align': 'right',
                                'value': 'MontoItem',
                                'format': 'number'
                            }
                        } %}
                        {# Renderizar encabezados dinámicamente -#}
                        {% for key, column in columns %}
                            {% if column.show %}
                                <th style="width: {{ column.width }}; text-align: {{ column.align }};">{{ column.title }}</th>
                            {% endif %}
                        {% endfor %}
                    </tr>
                </thead>
                {# Cuerpo de la Tabla -#}
                <tbody>
                    {% set subtotal = 0 %}
                    {% for detalle in document.Detalle %}
                        <tr>
                            {% for key, column in columns %}
                                {% if column.show %}
                                    <td style="text-align: {{ column.align }};">
                                        {% if key == 'item' %}
                                            <div>
                                                {{ attribute(detalle, column.value)
                                                    | default('') }}
                                            </div>
                                            {% if attribute(detalle, column.description) is not empty %}
                                                <div style="font-size: 6pt;">
                                                    {{ attribute(detalle, column.description)
                                                        | default('') }}
                                                </div>
                                            {% endif %}
                                        {% elseif column.format == 'indexe' %}
                                            {% if detalle.IndExe == 1 %}EX{% elseif detalle.IndExe == 2 %}NF{% endif %}
                                        {% elseif key == 'descuento' %}
                                            {% if detalle.DescuentoPct is not empty %}
                                                {{ detalle.DescuentoPct }}%
                                            {% elseif detalle.DescuentoMonto is not empty %}
                                                {{ detalle.DescuentoMonto | number_format(0, ',', '.') }}
                                            {% endif %}
                                        {% elseif column.format == 'number' %}
                                            {{ attribute(detalle, column.value) is not empty
                                                ? attribute(detalle, column.value)
                                                | number_format(0, ',', '.')
                                                : '' }}
                                        {% elseif key == 'codigo' %}
                                            {{ detalle.CdgItem is not empty and detalle.CdgItem.VlrCodigo is not empty
                                                ? detalle.CdgItem.VlrCodigo
                                                : '' }}
                                        {% else %}
                                            {{ attribute(detalle, column.value)
                                                | default('') }}
                                        {% endif %}
                                    </td>
                                {% endif %}
                            {% endfor %}
                        </tr>
                        {% if detalle.MontoItem is not empty %}
                            {% set subtotal = subtotal + detalle.MontoItem %}
                        {% endif %}
                    {% endfor %}
                </tbody>
            </table>
        </div>
        {% if document.DscRcgGlobal is not empty %}
        <div class="container container-montos-globales">
            <table class="tabla-montos-global">
                <tbody style="text-align: left;">
                    <tr>
                        <td class="label">
                            Subtotal:
                        </td>
                        <td>
                            {{ subtotal
                                | number_format(0, ',', '.') }}
                        </td>
                    </tr>
                    {# Descuento o Recargo #}
                    {% for descuento in document.DscRcgGlobal %}
                    {% set drTipo = (descuento.TpoMov | trim | upper == "D") ? "Descuento" : "Recargo" %}
                    {% if descuento.IndExeDR is not empty %}{% set drTipo = drTipo ~ ' EX' %}{% endif %}
                    <tr>
                        <td class="label">
                            {{ drTipo }}{% if (descuento.TpoValor | trim) == '$' %} ${% endif %}{% if descuento.GlosaDR is not empty %} ({{ descuento.GlosaDR }}){% endif %}:
                        </td>
                        <td>
                            {% if (descuento.TpoValor | trim) == '%' %}
                                {{ descuento.ValorDR }}%
                            {% else %}
                                {{ descuento.ValorDR | number_format(0, ',', '.') }}
                            {% endif %}
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
        {% endif %}
        {# Pagos programados #}
        {% if document.Encabezado.IdDoc.MntPagos is not empty %}
        <div class="container-observacion">
            <p>
                <span class="bold">Pago(s) programado(s):</span>
                {% set pagosArr = document.Encabezado.IdDoc.MntPagos %}
                {% if pagosArr.FchPago is defined %}{% set pagosArr = [pagosArr] %}{% endif %}
                {% for pago in pagosArr %}
                    - {{ pago.FchPago | date('d/m/Y') }}: ${{ pago.MntPago | number_format(0, ',', '.') }}.-{% if pago.GlosaPagos is not empty %} ({{ pago.GlosaPagos }}){% endif %}
                {% endfor %}
            </p>
        </div>
        {% endif %}
        {# Observación #}
        {% if document.Encabezado.IdDoc.TermPagoGlosa is not empty
            or document.Encabezado.IdDoc.MedioPago is not empty
            or document.Encabezado.IdDoc.TermPagoDias is not empty %}
        <div class="container-observacion">
            {% if document.Encabezado.IdDoc.TermPagoGlosa is not empty %}
            <p>
                <span class="bold">Observación:</span>
                {{ document.Encabezado.IdDoc.TermPagoGlosa | raw }}
            </p>
            {% endif %}
            {% if document.Encabezado.IdDoc.MedioPago is not empty or document.Encabezado.IdDoc.TermPagoDias is not empty %}
            <p>
                {% set pagoInfo = [] %}
                {% if document.Encabezado.IdDoc.MedioPago is not empty %}
                    {% set medio = 'Medio de pago: ' ~ (document.Encabezado.IdDoc.MedioPago | format_as('billing_document.MedioPago')) %}
                    {% if document.Encabezado.IdDoc.BcoPago is not empty %}{% set medio = medio ~ ' a ' ~ document.Encabezado.IdDoc.BcoPago %}{% endif %}
                    {% if document.Encabezado.IdDoc.TpoCtaPago is not empty %}{% set medio = medio ~ ' en cuenta ' ~ (document.Encabezado.IdDoc.TpoCtaPago | lower) %}{% endif %}
                    {% if document.Encabezado.IdDoc.NumCtaPago is not empty %}{% set medio = medio ~ ' N° ' ~ document.Encabezado.IdDoc.NumCtaPago %}{% endif %}
                    {% set pagoInfo = pagoInfo | merge([medio]) %}
                {% endif %}
                {% if document.Encabezado.IdDoc.TermPagoDias is not empty %}
                    {% set pagoInfo = pagoInfo | merge(['Días de pago: ' ~ document.Encabezado.IdDoc.TermPagoDias]) %}
                {% endif %}
                {{ pagoInfo | join(' / ') }}
            </p>
            {% endif %}
        </div>
        {% endif %}
        <div class="container-informacion-bottom"{% if acuse_recibo is empty %}style="bottom: 130px;"{% endif %}>
            <table class="tabla-bottom-element">
                <tr>
                    <td class="tabla-bottom-element-cell">
                        {# Contenedor del Timbre #}
                        {% if document_stamp is not empty %}
                            <table class="tabla-timbre">
                                <tr>
                                    <td>
                                        <img class="img-timbre" src="{{ document_stamp | format_as('billing_document.TED') }}" alt="Timbre Electrónico: TED en formato PDF417">
                                    </td>
                                </tr>
                                <tr>
                                    <td class="timbre-text">Timbre Electrónico S.I.I.</td>
                                </tr>
                                <tr>
                                    {% if document_auth is not empty %}
                                        <td class="timbre-text">
                                            Resolución {{ document_auth.NroResol }} del {{ document_auth.FchResol | format_as('billing_document.FchResol') }}
                                        </td>
                                    {% endif %}
                                </tr>
                                <tr>
                                    <td class="timbre-text">Verifique documento en: www.sii.cl</td>
                                </tr>
                            </table>
                        {% endif %}
                    </td>
                    {% if acuse_recibo is not empty %}
                        <td class="tabla-bottom-element-cell">
                        {# Acuse de Recibo -#}
                            <table class="acuse-recibo">
                                <tr>
                                    <td colspan="2" class="acuse-title">Acuse de recibo</td>
                                </tr>
                                <tr>
                                    <td class="label">Nombre</td>
                                    <td class="linea">__________________________</td>
                                </tr>
                                <tr>
                                    <td class="label">RUN</td>
                                    <td class="linea">__________________________</td>
                                </tr>
                                <tr>
                                    <td class="label">Fecha</td>
                                    <td class="linea">__________________________</td>
                                </tr>
                                <tr>
                                    <td class="label">Recinto</td>
                                    <td class="linea">__________________________</td>
                                </tr>
                                <tr>
                                    <td class="label">Firma</td>
                                    <td class="linea">__________________________</td>
                                </tr>
                            </table>
                            <p class="acuse-recibo-label">
                                El acuse de recibo que se declara en este acto, de acuerdo a lo dispuesto en la letra b) del Art.4°, y la letra c) del Art. 5° de la Ley 19.983, acredita que la entrega de mercaderías o servicio(s) prestado(s) ha(n) sido recibido(s).
                            </p>
                        </td>
                    {% endif %}
                    <td class="tabla-bottom-element-cell">
                        {# Montos #}
                        <table class="tabla-montos">
                            <tbody>
                                {% set otraMoneda = document.Encabezado.Totales.TpoMoneda is not empty and document.Encabezado.Totales.TpoMoneda == 'DOLAR USA' %}
                                {# Neto -#}
                                {% if document.Encabezado.Totales.MntNeto is not empty %}
                                    <tr>
                                        <td> Neto $: </td>
                                        <td>
                                            {% if otraMoneda %}
                                                {{ document.Encabezado.Totales.MntNeto
                                                    | number_format(2, '.', ',') }}
                                            {% else %}
                                                {{ document.Encabezado.Totales.MntNeto
                                                    | number_format(0, ',', '.') }}
                                            {% endif %}
                                        </td>
                                    </tr>
                                {% endif %}
                                {# Monto -#}
                                {% if document.Encabezado.Totales.TpoMoneda is not empty %}
                                    <tr>
                                        <td> Moneda: </td>
                                        <td>
                                            {{ document.Encabezado.Totales.TpoMoneda }}
                                        </td>
                                    </tr>
                                {% endif %}
                                {# Exento -#}
                                {% if document.Encabezado.Totales.MntExe is not empty %}
                                    <tr>
                                        <td> Exento $: </td>
                                        <td>
                                            {% if otraMoneda %}
                                                {{ document.Encabezado.Totales.MntExe
                                                    | number_format(2, '.', ',') }}
                                            {% else %}
                                                {{ document.Encabezado.Totales.MntExe
                                                    | number_format(0, ',', '.') }}
                                            {% endif %}
                                        </td>
                                    </tr>
                                {% endif %}
                                {# IVA -#}
                                {% if document.Encabezado.Totales.IVA is not empty %}
                                    <tr>
                                        <td>
                                            IVA {{ document.Encabezado.Totales.TasaIVA is not empty
                                                ? '(' ~ document.Encabezado.Totales.TasaIVA ~ '%):'
                                                : '$:' }}
                                        </td>
                                        <td>
                                            {% if otraMoneda %}
                                                {{ document.Encabezado.Totales.IVA
                                                    | number_format(2, '.', ',') }}
                                            {% else %}
                                                {{ document.Encabezado.Totales.IVA
                                                    | number_format(0, ',', '.') }}
                                            {% endif %}
                                        </td>
                                    </tr>
                                {% endif %}
                                {# IVA no retenido -#}
                                {% if document.Encabezado.Totales.IVANoRet is not empty %}
                                    <tr>
                                        <td>
                                            IVA no retenido:
                                        </td>
                                        <td>
                                            {% if otraMoneda %}
                                                {{ document.Encabezado.Totales.IVANoRet
                                                    | number_format(2, '.', ',') }}
                                            {% else %}
                                                {{ document.Encabezado.Totales.IVANoRet
                                                    | number_format(0, ',', '.') }}
                                            {% endif %}
                                        </td>
                                    </tr>
                                {% endif %}
                                {# Crédito consumo en el exterior -#}
                                {% if document.Encabezado.Totales.CredEC is not empty %}
                                    <tr>
                                        <td>Desc. 65% IVA $:</td>
                                        <td>
                                            {% if otraMoneda %}
                                                {{ document.Encabezado.Totales.CredEC
                                                    | number_format(2, '.', ',') }}
                                            {% else %}
                                                {{ document.Encabezado.Totales.CredEC
                                                    | number_format(0, ',', '.') }}
                                            {% endif %}
                                        </td>
                                    </tr>
                                {% endif %}
                                {# IVA adicional -#}
                                {% if document.Encabezado.Totales.ImptoReten is not empty %}
                                    {% for impuesto in document.Encabezado.Totales.ImptoReten %}
                                    <tr>
                                        <td>
                                            {{ impuesto.TipoImp | format_as('billing_document.TipoImp') }}{% if impuesto.TasaImp is not empty %} ({{ impuesto.TasaImp }}%){% endif %} $:
                                        </td>
                                        <td>
                                            {% if otraMoneda %}
                                                {{ impuesto.MontoImp
                                                    | number_format(2, '.', ',') }}
                                            {% else %}
                                                {{ impuesto.MontoImp
                                                    | number_format(0, ',', '.') }}
                                            {% endif %}
                                        </td>
                                    </tr>
                                    {% endfor %}
                                {% endif %}
                                {# Total -#}
                                <tr>
                                    <td>Total $:</td>
                                    <td>
                                        {% if otraMoneda %}
                                            {{ document.Encabezado.Totales.MntTotal
                                                | number_format(2, '.', ',') }}
                                        {% else %}
                                            {{ document.Encabezado.Totales.MntTotal
                                                | number_format(0, ',', '.') }}
                                        {% endif %}
                                    </td>
                                </tr>
                                {# No facturable -#}
                                {% if document.Encabezado.Totales.MontoNF is not empty %}
                                    <tr>
                                        <td>No facturable $:</td>
                                        <td>
                                            {% if otraMoneda %}
                                                {{ document.Encabezado.Totales.MontoNF
                                                    | number_format(2, '.', ',') }}
                                            {% else %}
                                                {{ document.Encabezado.Totales.MontoNF
                                                    | number_format(0, ',', '.') }}
                                            {% endif %}
                                        </td>
                                    </tr>
                                {% endif %}
                                {# Total PESO CL -#}
                                {% if document.Encabezado.OtraMoneda is not empty %}
                                    <tr>
                                        <td>Total {{ document.Encabezado.OtraMoneda.TpoMoneda }}:</td>
                                        <td>
                                            {{ document.Encabezado.OtraMoneda.MntTotOtrMnda
                                                | number_format(0, ',', '.') }}
                                        </td>
                                    </tr>
                                {% endif %}
                                {# Monto periodo -#}
                                {% if document.Encabezado.Totales.MontoPeriodo is not empty %}
                                    <tr>
                                        <td>
                                            Monto período $:
                                        </td>
                                        <td>
                                            {% if otraMoneda %}
                                                {{ document.Encabezado.Totales.MontoPeriodo
                                                    | number_format(2, '.', ',') }}
                                            {% else %}
                                                {{ document.Encabezado.Totales.MontoPeriodo
                                                    | number_format(0, ',', '.') }}
                                            {% endif %}
                                        </td>
                                    </tr>
                                {% endif %}
                                {# Saldo anterior -#}
                                {% if document.Encabezado.Totales.SaldoAnterior is not empty %}
                                    <tr>
                                        <td>Saldo anterior $:</td>
                                        <td>
                                            {% if otraMoneda %}
                                                {{ document.Encabezado.Totales.SaldoAnterior
                                                    | number_format(2, '.', ',') }}
                                            {% else %}
                                                {{ document.Encabezado.Totales.SaldoAnterior
                                                    | number_format(0, ',', '.') }}
                                            {% endif %}
                                        </td>
                                    </tr>
                                {% endif %}
                                {# Valor a pagar -#}
                                {% if document.Encabezado.Totales.VlrPagar is not empty %}
                                    <tr>
                                        <td>Valor a pagar $:</td>
                                        <td>
                                            {% if otraMoneda %}
                                                {{ document.Encabezado.Totales.VlrPagar
                                                    | number_format(2, '.', ',') }}
                                            {% else %}
                                                {{ document.Encabezado.Totales.VlrPagar
                                                    | number_format(0, ',', '.') }}
                                            {% endif %}
                                        </td>
                                    </tr>
                                {% endif %}
                            </tbody>
                        </table>
                    </td>
                </tr>
            </table>
        </div>
        {% if acuse_recibo is not empty %}
            <div class="container container-cedible">
                <p class="cedible">
                    {% if document.Encabezado.IdDoc.TipoDTE in ['52', '56', '61'] %}
                        CEDIBLE CON SU FACTURA
                    {% else %}
                        CEDIBLE
                    {% endif %}
                </p>
            </div>
        {% endif %}
        {# Footer #}
        <footer>
            <div class="container-footer">
                <div class="footer-text">
                    Boletas y facturas generadas con LibreDTE
                </div>
                <div class="footer-link">
                    <a href="https://www.libredte.cl" style="text-decoration: none; color: inherit;" target="_blank">
                        www.libredte.cl
                    </a>
                </div>
            </div>
        </footer>
    </body>
</html>
